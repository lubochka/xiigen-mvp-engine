  "ironRules": [
    {
      "id": "IR-T619-1",
      "rule": "SETNX(node-type-reg-lock:{nodeTypeId}) at ORDER 1 before either write. NodeTypeAlreadyExists emitted on lock held.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T619-2",
      "rule": "storeDocument(nodeType, GLOBAL) at ORDER 2 — first of the dual write. If this fails, redis.del(lockKey) in catch.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T619-3",
      "rule": "storeDocument(capabilityIndex) at ORDER 3 — second of the dual write. If this fails, redis.del(lockKey) in catch.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T619-4",
      "rule": "redis.del(lockKey) MUST be called in catch block on any write failure. Missing redis.del = hung lock = future registrations permanently blocked.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T619-5",
      "rule": "storeDocument(audit) at ORDER 4 BEFORE NodeTypeRegistered emit. DNA-8.",
      "severity": "BUILD_FAILURE"
    }
  ],
