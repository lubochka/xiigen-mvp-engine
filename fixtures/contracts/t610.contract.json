{
  "taskTypeId": "T610",
  "flowId": "FLOW-16",
  "name": "MarketplacePaymentSplitter",
  "archetype": "TRANSACTION",
  "domainId": "marketplace-payments",
  "seededAt": "2026-04-13T00:00:00Z",
  "ironRules": [
    {
      "id": "IR-T610-1",
      "rule": "SETNX idempotency key MUST be hash(tenantId+cartId+totalAmountCents) — NOT cartId alone. cartId-only allows retry with different totalAmountCents to double-charge.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T610-2",
      "rule": "platformFeeBps MUST come from FREEDOM config key 'platform_fee_bps'. Hardcoded fee = BUILD_FAILURE.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T610-3",
      "rule": "PII MUST be scrubbed from all audit records before storeDocument. No card numbers, CVVs, or full PAN fields in nonRepudiationAudit records.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T610-4",
      "rule": "nonRepudiationAudit index MUST be append-only. No deleteDocument or updateDocument calls on xiigen-nra-audit. prevHash MUST be included to form a cryptographic chain.",
      "severity": "BUILD_FAILURE"
    },
    {
      "id": "IR-T610-5",
      "rule": "escrow record MUST be stored BEFORE MarketplaceOrderConfirmed is emitted (DNA-8). Downstream consumers depend on escrow existence.",
      "severity": "BUILD_FAILURE"
    }
  ],
