{
  "name": "@xiigen/miro-ai-architect",
  "version": "1.0.1",
  "license": "AGPL-3.0-only",
  "description": "FT-M1 Miro adapter for the XIIGen AI Architect and FLOW-42 shape heuristics path. Reads Miro board items and maps them through the shared architecture engine.",
  "private": false,
  "main": "dist/bundle.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "__tests__",
    "docs",
    "dist",
    "tsconfig.json",
    "webpack.config.js"
  ],
  "publishConfig": {
    "registry": "http://localhost:4873",
    "access": "public"
  },
  "scripts": {
    "build": "webpack --mode production",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@mirohq/miro-api": "^3.0.0",
    "@mirohq/websdk-types": "^2.0.0",
    "@xiigen/plugin-sdk": "*"
  },
  "peerDependenciesMeta": {
    "@mirohq/miro-api": {
      "optional": true
    },
    "@mirohq/websdk-types": {
      "optional": true
    },
    "@xiigen/plugin-sdk": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/jest": "^29.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0",
    "ts-loader": "^9.0.0",
    "webpack": "^5.0.0",
    "webpack-cli": "^5.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.spec.ts"
    ]
  },
  "keywords": [
    "xiigen",
    "miro",
    "ai-architect",
    "shape-heuristics",
    "adapter",
    "MODE-B",
    "ADAPTATION"
  ]
}
