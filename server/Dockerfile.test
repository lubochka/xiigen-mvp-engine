# ═══════════════════════════════════════════════════════
# XIIGen Server — E2E Test Container
# ═══════════════════════════════════════════════════════
# Builds the NestJS server and runs it on port 3000.
# Used by the ui-e2e Docker profile for Playwright tests.

FROM node:20-alpine

LABEL description="XIIGen Server — E2E test container"

WORKDIR /app

# Copy package files first (cache layer)
COPY server/package.json server/package-lock.json ./

# Install dependencies
RUN npm ci

# Copy source and tsconfig
COPY server/tsconfig.json ./
COPY server/src/ ./src/

# Build NestJS
RUN npm run build

EXPOSE 3000

# Health check — /health/live always returns 200
HEALTHCHECK --interval=5s --timeout=3s --retries=10 \
  CMD wget -q --spider http://localhost:3000/health/live || exit 1

CMD ["node", "dist/main.js"]
