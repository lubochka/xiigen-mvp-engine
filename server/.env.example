# XIIGen Server — Environment Variable Reference
# Copy to .env and fill in your values. Never commit .env with real keys.

PORT=3000
NODE_ENV=development
LOG_LEVEL=info

# Fabric providers
DATABASE_PROVIDER=in_memory
QUEUE_PROVIDER=in_memory

# Elasticsearch (only if DATABASE_PROVIDER=elasticsearch)
ELASTICSEARCH_URL=http://localhost:9200
ES_URL=http://localhost:9200

# Redis (only if QUEUE_PROVIDER=redis)
REDIS_URL=redis://localhost:6379

# AI Provider mode — set to 'mock' for zero-cost logic verification (development default)
AI_PROVIDER=mock

# ── BOOTSTRAP_* keys (first-time setup only) ────────────────────────────────
# ONLY needed on first boot if you have no Elasticsearch to persist keys.
# After first boot: provision keys via API and DELETE these lines:
#
#   PUT /api/tenants/{masterTenantId}/keys
#   { "anthropic": "sk-ant-...", "openai": "sk-...", "gemini": "AIza..." }
#
# Once provisioned, keys live encrypted in xiigen-byok-keys (ES) only.
# TENANT_KEY_ENCRYPTION_SECRET (below) is the only permanent key in .env.
#
# BOOTSTRAP_ANTHROPIC_KEY=sk-ant-...
# BOOTSTRAP_OPENAI_KEY=sk-...
# BOOTSTRAP_GEMINI_KEY=AIza...

# BYOK Encryption Secret — 32-char AES-256-GCM key
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex').slice(0,32))"
TENANT_KEY_ENCRYPTION_SECRET=your-32-character-secret-here--x

# Default tenant ID
DEFAULT_TENANT_ID=default

# Subdomain routing (optional)
SUBDOMAIN_BASE_DOMAIN=
