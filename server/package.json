{
  "name": "xiigen-server",
  "version": "1.0.0",
  "description": "XIIGen Self-Building Engine — NestJS Translation",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "test": "jest --verbose",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:docker": "SKIP_DOCKER_TESTS=0 jest --testPathPatterns=docker-integration --verbose --runInBand",
    "test:docker:check": "echo 'Checking...' && curl -sf http://localhost:19200/_cluster/health > /dev/null && echo 'ES: OK' || echo 'ES: DOWN'",
    "lint:naming": "node scripts/naming-lint.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings 0",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "xiigen",
    "engine",
    "nestjs",
    "fabric-first"
  ],
  "author": "Luba",
  "license": "AGPL-3.0-only",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.81.0",
    "@google/generative-ai": "^0.24.1",
    "@nestjs/common": "^11.1.16",
    "@nestjs/core": "^11.1.16",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.16",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/testing": "^11.1.16",
    "@types/adm-zip": "^0.5.8",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.0",
    "jsonwebtoken": "^9.0.3",
    "nestjs-cls": "^6.2.0",
    "openai": "^6.33.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.16",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.3",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "eslint": "^8.57.0",
    "jest": "^30.2.0",
    "prettier": "^3.3.3",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
