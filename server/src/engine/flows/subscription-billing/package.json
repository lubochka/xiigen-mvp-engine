  "license": "AGPL-3.0-only",
  "description": "FLOW-12 subscription-billing - recurring plan publication, subscription lifecycle, invoice charging, and billing analytics lifecycle (T209-T212). Portability artifact declaring the four-hop billing co-install chain.",
  "flowId": "FLOW-12",
  "flowSlug": "subscription-billing",
  "xiigenFlowMeta": {
    "connectionType": "FLOW_SCOPED",
    "services": [
      "SubscriptionPlanOrchestratorService",
      "SubscriptionLifecycleManagerService",
      "RecurringBillingEngineService",
      "SubscriptionAnalyticsAggregatorService"
    ],
    "taskTypeIds": [
      "T209",
      "T210",
      "T211",
      "T212"
    ],
    "freedomKeys": [
      "subscription_billing_plan_audit_retention",
      "subscription_billing_default_trial_days",
      "subscription_billing_dunning_schedule",
      "subscription_billing_metrics_window_days"
    ],
    "emitsEventsConsumedBy": [
      "FLOW-12 tenant billing dashboard and analytics consumers"
    ],
    "readsFromOtherFlows": [
      "FLOW-09 (IPaymentFabricService and transactional payment records)",
      "FLOW-04 (event-attendance records required by FLOW-09)",
      "FLOW-03 (event-management records required by FLOW-04)"
    ],
    "portabilityTier": "TIER-D",
    "portabilityStatus": "MOBILE_CANDIDATE_IN_GENERATION"
