      "@xiigen/transactional-event-participation",
      "@xiigen/event-attendance",
      "@xiigen/event-management"
    ],
    "pluginSdk": "@xiigen/plugin-sdk@^1.0.0"
  },
  "requiredCoInstalls": [
    "@xiigen/transactional-event-participation",
    "@xiigen/event-attendance",
    "@xiigen/event-management"
  ],
  "coInstallNotes": "FLOW-12 reuses FLOW-09 payment fabric behavior and must declare the full FLOW-09 -> FLOW-04 -> FLOW-03 chain. FLOW-03 is a required upstream hop for the chain but remains standalone; it is declared once and not bundled or double-installed inside the FLOW-12 package.",
  "peerDependencies": {
    "xiigen-server": "^1.0.0",
    "@xiigen/transactional-event-participation": "^1.0.0",
    "@xiigen/event-attendance": "^1.0.0",
