{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "OAuthTokenExchangeCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data","sessionId","clientTimestamp"],
  "properties": {
    "eventType": { "type": "string", "const": "OAuthTokenExchangeCompleted" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "sessionId": { "type": "string", "description": "Per-exchange session ID — never reused" },
    "clientTimestamp": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["connectorId","tokenVaultRef"],
      "properties": {
        "connectorId": { "type": "string" },
        "tokenVaultRef": { "type": "string", "description": "Opaque vault reference — never raw token" }
      }
    }
  }
}
