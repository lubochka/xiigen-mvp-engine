{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AiTokenBudgetSet",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "AiTokenBudgetSet" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["budgetId","limitTokens"],
      "properties": {"budgetId":{"type":"string"},"limitTokens":{"type":"integer","description":"From FREEDOM config flow15_ai_token_budget_limit"}}
    }
  }
}
