{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PluginReviewCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "PluginReviewCompleted" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["pluginId","verdict"],
      "properties": {"pluginId":{"type":"string"},"verdict":{"type":"string","enum":["APPROVED","REJECTED"]}}
    }
  }
}
