{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IntegrationHealthChecked",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "IntegrationHealthChecked" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["integrationId","status"],
      "properties": {"integrationId":{"type":"string"},"status":{"type":"string","enum":["healthy","degraded","unreachable"]}}
    }
  }
}
