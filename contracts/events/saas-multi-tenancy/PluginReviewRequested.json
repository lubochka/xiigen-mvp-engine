{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PluginReviewRequested",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "PluginReviewRequested" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["pluginId","submittedBy"],
      "properties": {"pluginId":{"type":"string"},"submittedBy":{"type":"string"}}
    }
  }
}
