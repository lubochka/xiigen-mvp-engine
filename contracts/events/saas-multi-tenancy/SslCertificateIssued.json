{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SslCertificateIssued",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "SslCertificateIssued" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["certId","domain","expiresAt"],
      "properties": {"certId":{"type":"string"},"domain":{"type":"string"},"expiresAt":{"type":"string","format":"date-time"}}
    }
  }
}
