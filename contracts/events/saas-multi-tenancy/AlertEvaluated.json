{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AlertEvaluated",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "AlertEvaluated" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["alertId","result"],
      "properties": {"alertId":{"type":"string"},"result":{"type":"string","enum":["FIRING","RESOLVED","SUPPRESSED"]}}
    }
  }
}
