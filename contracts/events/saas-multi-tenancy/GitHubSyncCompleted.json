{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "GitHubSyncCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "GitHubSyncCompleted" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["repoId","syncCursor","committedAt"],
      "properties": {"repoId":{"type":"string"},"syncCursor":{"type":"string","description":"Cursor stored in PostgreSQL only — never Redis"},"committedAt":{"type":"string","format":"date-time"}}
    }
  }
}
