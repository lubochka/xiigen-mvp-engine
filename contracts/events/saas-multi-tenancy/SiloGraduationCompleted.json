{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SiloGraduationCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "SiloGraduationCompleted" },
    "flowId": { "type": "string", "const": "FLOW-15" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["tenantId","fromTier","toTier","irreversible"],
      "properties": {
        "tenantId": { "type": "string" },
        "fromTier": { "type": "string", "const": "shared" },
        "toTier": { "type": "string", "const": "dedicated" },
        "irreversible": { "type": "boolean", "const": true }
      }
    }
  }
}
