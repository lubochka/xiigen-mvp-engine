{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SchemaRegistered",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.schema.registered"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["schemaId", "tenantId", "changeType"],
      "properties": {
        "schemaId": { "type": "string" },
        "tenantId": { "type": "string" },
        "changeType": { "type": "string", "enum": ["ADDITIVE", "BREAKING"] }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
