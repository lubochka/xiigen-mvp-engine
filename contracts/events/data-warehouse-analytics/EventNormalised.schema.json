{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "EventNormalised",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.event.normalised"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["batchId", "tenantId", "normalizedAt", "eventCount"],
      "properties": {
        "batchId": { "type": "string" },
        "tenantId": { "type": "string" },
        "normalizedAt": { "type": "string", "format": "date-time" },
        "eventCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
