{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ContentRetentionExtended",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.content.retention.extended"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["contentId", "tenantId", "reason", "extendedUntil"],
      "properties": {
        "contentId": { "type": "string" },
        "tenantId": { "type": "string" },
        "reason": {
          "type": "string",
          "enum": ["legal_hold_active"]
        },
        "extendedUntil": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
