{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KPISnapshotGenerated",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.kpi.snapshot"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["kpiId", "tenantId", "value", "alertFired"],
      "properties": {
        "kpiId": { "type": "string" },
        "tenantId": { "type": "string" },
        "value": { "type": "number" },
        "alertFired": { "type": "boolean" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
