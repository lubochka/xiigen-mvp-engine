{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FunnelAnalysisGenerated",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.funnel.analysis"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["funnelId", "tenantId", "conversionRate", "steps"],
      "properties": {
        "funnelId": { "type": "string" },
        "tenantId": { "type": "string" },
        "conversionRate": { "type": "number", "minimum": 0, "maximum": 1 },
        "steps": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
