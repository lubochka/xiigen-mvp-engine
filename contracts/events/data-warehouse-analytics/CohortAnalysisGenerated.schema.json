{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CohortAnalysisGenerated",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.cohort.analysis"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["cohortId", "tenantId", "cohortSize", "analysisDate"],
      "properties": {
        "cohortId": { "type": "string" },
        "tenantId": { "type": "string" },
        "cohortSize": { "type": "integer", "minimum": 0 },
        "analysisDate": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
