{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MetricAggregated",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.metric.aggregated"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["metricId", "tenantId", "windowStart", "windowEnd", "value"],
      "properties": {
        "metricId": { "type": "string" },
        "tenantId": { "type": "string" },
        "windowStart": { "type": "string", "format": "date-time" },
        "windowEnd": { "type": "string", "format": "date-time" },
        "value": { "type": "number" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
