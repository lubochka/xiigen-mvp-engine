{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CrossFlowCorrelationReported",
  "type": "object",
  "required": ["specversion", "type", "source", "id", "time", "data"],
  "properties": {
    "specversion": { "type": "string", "enum": ["1.0"] },
    "type": { "type": "string", "enum": ["warehouse.crossflow.correlation"] },
    "source": { "type": "string" },
    "id": { "type": "string" },
    "time": { "type": "string", "format": "date-time" },
    "data": {
      "type": "object",
      "required": ["correlationId", "tenantId", "sourceFlows", "result"],
      "properties": {
        "correlationId": { "type": "string" },
        "tenantId": { "type": "string" },
        "sourceFlows": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 2
        },
        "result": { "type": "object" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
