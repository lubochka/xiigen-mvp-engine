{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReverseETLPushed",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "ReverseETLPushed" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["connectorId","recordsPushed","transport","rateLimitChecked"],
      "properties": {
        "connectorId": { "type": "string" },
        "recordsPushed": { "type": "integer" },
        "transport": { "type": "string", "const": "queue_fabric", "description": "DR-64: no direct HTTP" },
        "rateLimitChecked": { "type": "boolean" }
      }
    }
  }
}
