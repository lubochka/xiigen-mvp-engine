{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StagingRecordWritten",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "StagingRecordWritten" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["recordId","sourceZone","targetZone","idempotencyKey"],
      "properties": {
        "recordId": { "type": "string" },
        "sourceZone": { "type": "string", "const": "raw" },
        "targetZone": { "type": "string", "const": "staging" },
        "idempotencyKey": { "type": "string", "description": "DNA-7: deduplication key" }
      }
    }
  }
}
