{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SchemaDriftDetected",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "SchemaDriftDetected" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["connectorId","driftType","affectedFields","driftScore"],
      "properties": {
        "connectorId": { "type": "string" },
        "driftType": { "type": "string", "enum": ["new_field","type_change","field_removed"] },
        "affectedFields": { "type": "array", "items": { "type": "string" } },
        "driftScore": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    }
  }
}
