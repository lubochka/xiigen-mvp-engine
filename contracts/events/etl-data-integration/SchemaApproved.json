{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SchemaApproved",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "SchemaApproved" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["connectorId","schemaVersion","approvedBy"],
      "properties": {
        "connectorId": { "type": "string" },
        "schemaVersion": { "type": "string" },
        "approvedBy": { "type": "string" }
      }
    }
  }
}
