{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BackfillFailed",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "BackfillFailed" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["jobId","connectorId","errorCode","errorMessage","failedSlice"],
      "properties": {
        "jobId": { "type": "string" },
        "connectorId": { "type": "string" },
        "errorCode": { "type": "string" },
        "errorMessage": { "type": "string" },
        "failedSlice": { "type": "string", "description": "The time slice or partition that failed during backfill" }
      }
    }
  }
}
