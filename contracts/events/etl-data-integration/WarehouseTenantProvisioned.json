{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WarehouseTenantProvisioned",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "WarehouseTenantProvisioned" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["warehouseId","zonesProvisioned","rlsPoliciesRegistered"],
      "properties": {
        "warehouseId": { "type": "string" },
        "zonesProvisioned": { "type": "array", "items": { "type": "string", "enum": ["raw","staging","core","mart"] } },
        "rlsPoliciesRegistered": { "type": "boolean" }
      }
    }
  }
}
