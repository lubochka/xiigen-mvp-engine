{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "KPIComputationCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "KPIComputationCompleted" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["kpiId","martId","computedAt","resultCount"],
      "properties": {
        "kpiId": { "type": "string" },
        "martId": { "type": "string" },
        "computedAt": { "type": "string", "format": "date-time" },
        "resultCount": { "type": "integer" }
      }
    }
  }
}
