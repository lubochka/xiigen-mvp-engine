{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConnectorRegistrationFailed",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "ConnectorRegistrationFailed" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["connectorId","errorCode","errorMessage"],
      "properties": {
        "connectorId": { "type": "string" },
        "errorCode": { "type": "string" },
        "errorMessage": { "type": "string" }
      }
    }
  }
}
