{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IdentityJoinCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "IdentityJoinCompleted" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["joinId","identitiesResolved","confidenceScore","crossTenantGuardPassed"],
      "properties": {
        "joinId": { "type": "string" },
        "identitiesResolved": { "type": "integer" },
        "confidenceScore": { "type": "number", "minimum": 0, "maximum": 1 },
        "crossTenantGuardPassed": { "type": "boolean", "description": "CF-204: all inputs had matching tenantId" }
      }
    }
  }
}
