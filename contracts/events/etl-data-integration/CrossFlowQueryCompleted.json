{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CrossFlowQueryCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "CrossFlowQueryCompleted" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["queryId","sourceFlows","resultCount","rlsApplied"],
      "properties": {
        "queryId": { "type": "string" },
        "sourceFlows": { "type": "array", "items": { "type": "string" }, "description": "Includes FLOW-13" },
        "resultCount": { "type": "integer" },
        "rlsApplied": { "type": "boolean", "description": "F463: RLS policy enforced on results" }
      }
    }
  }
}
