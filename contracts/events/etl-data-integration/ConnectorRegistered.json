{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ConnectorRegistered",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "ConnectorRegistered" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["connectorId","connectorType","healthStatus"],
      "properties": {
        "connectorId": { "type": "string", "description": "Opaque connector reference — no credentials" },
        "connectorType": { "type": "string" },
        "healthStatus": { "type": "string", "enum": ["healthy","degraded","unreachable"] }
      }
    }
  }
}
