{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FactAppended",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "FactAppended" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["factId","coreZoneId","dimensionRefs","idempotencyKey"],
      "properties": {
        "factId": { "type": "string" },
        "coreZoneId": { "type": "string" },
        "dimensionRefs": { "type": "array", "items": { "type": "string" } },
        "idempotencyKey": { "type": "string" }
      }
    }
  }
}
