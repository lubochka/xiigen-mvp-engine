{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "PiiClassificationCompleted",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "PiiClassificationCompleted" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["classificationId","piiFieldsDetected","martWriteApproved"],
      "properties": {
        "classificationId": { "type": "string" },
        "piiFieldsDetected": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Field names identified as containing PII"
        },
        "martWriteApproved": { "type": "boolean", "description": "Whether the record is approved for mart write after PII gate" }
      }
    }
  }
}
