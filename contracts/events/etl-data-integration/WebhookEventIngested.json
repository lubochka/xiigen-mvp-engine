{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "WebhookEventIngested",
  "type": "object",
  "required": ["eventType","flowId","correlationId","tenantId","timestamp","source","traceparent","data"],
  "properties": {
    "eventType": { "type": "string", "const": "WebhookEventIngested" },
    "flowId": { "type": "string", "const": "FLOW-14" },
    "correlationId": { "type": "string", "format": "uuid" },
    "tenantId": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "source": { "type": "string" },
    "traceparent": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["webhookId","connectorId","hmacVerified","rawZoneId"],
      "properties": {
        "webhookId": { "type": "string" },
        "connectorId": { "type": "string", "description": "Opaque — no credentials in payload (F427)" },
        "hmacVerified": { "type": "boolean", "description": "CF-211: timing-safe verification confirmed" },
        "rawZoneId": { "type": "string" }
      }
    }
  }
}
