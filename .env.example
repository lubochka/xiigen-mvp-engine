# ═══════════════════════════════════════════════════════
# XIIGen Engine — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Do NOT commit .env to version control.

# ── General ──────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ── Logging ──────────────────────────────────────────
LOG_LEVEL=info
LOG_PRETTY=false

# ── Fabric Providers ─────────────────────────────────
# Options: in_memory, elasticsearch
DATABASE_PROVIDER=in_memory

# Options: in_memory, redis_streams
QUEUE_PROVIDER=in_memory

# Options: mock, anthropic, openai, gemini, grok
AI_PROVIDER=mock

# Options: in_memory, split, fanout, tiered, hybrid
RAG_PROVIDER=in_memory

# Options: in_memory, env_var, aws
SECRETS_PROVIDER=in_memory

# ── Infrastructure URLs ──────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
REDIS_URL=redis://redis:6379

# ── AI Provider Keys ────────────────────────────────
# Per-tenant keys are managed via the /tenants/:id/keys API.
# These are fallback defaults used when no tenant key is set.
DEFAULT_ANTHROPIC_KEY=
DEFAULT_OPENAI_KEY=
DEFAULT_GEMINI_KEY=

# ── Multi-Tenant ─────────────────────────────────────
# Default tenant created on bootstrap
DEFAULT_TENANT_ID=default
DEFAULT_TENANT_NAME=Default Tenant

# ── Security ─────────────────────────────────────────
# Encryption key for tenant API keys at rest (base64, 32 bytes)
TENANT_KEY_ENCRYPTION_SECRET=

# ── Rate Limiting ────────────────────────────────────
# Default quota: max AI calls per tenant per minute
DEFAULT_AI_CALLS_PER_MINUTE=60
DEFAULT_TOKEN_BUDGET_PER_MINUTE=100000
