snapshots/*.json

# Claude Code worktrees — managed by Claude Code, not committed
.claude/worktrees/
playwright-results-flow48/
playwright.config.flow48.ts

# Design-skill refresh workspace — local-only extraction of third-party MIT-licensed
# skill zips (ui-ux-pro-max, impeccable, interface-design, design-for-ai) read for
# primary-source study during RUN-87. Do NOT commit their contents to this repo.
.design-refresh/

# Build artifacts — compiled output that must never re-enter the index
*.tsbuildinfo
__pycache__/

